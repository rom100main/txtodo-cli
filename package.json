{
    "name": "txtodo-cli",
    "version": "1.1.1",
    "description": "A CLI for txtodo a todo.txt parser/serializer with utils funcion, extension support and subtask handling",
    "keywords": [
        "cli",
        "todo.txt",
        "task-management"
    ],
    "homepage": "https://github.com/rom100main/txtodo-cli#readme",
    "bugs": {
        "url": "https://github.com/rom100main/txtodo-cli/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rom100main/txtodo-cli.git"
    },
    "license": "MIT",
    "author": "rom100main",
    "type": "commonjs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest",
        "clean": "rm -rf dist",
        "lint": "eslint . --ext .ts,.js",
        "lint:fix": "eslint . --ext .ts,.js --fix"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@typescript-eslint/eslint-plugin": "^8.46.2",
        "@typescript-eslint/parser": "^8.46.2",
        "eslint": "^9.38.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "jest": "^29.5.0",
        "prettier": "^3.6.2",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.0"
    },
    "files": [
        "dist/**/*"
    ],
    "bin": {
        "todotxt-mcp": "./dist/index.js"
    },
